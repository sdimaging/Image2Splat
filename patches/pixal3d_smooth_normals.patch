+def _smooth_vertex_normals(vertex_normal: torch.Tensor, faces: torch.Tensor,
+                           iters: int, crease_deg: float = 40.0) -> torch.Tensor:
+    """Crease-aware Laplacian smoothing of a per-vertex normal field.
+
+    Diffuses normals across mesh edges to flatten plateau-scale orientation
+    noise (generated geometry often undulates in ~10-20°-tilted patches that
+    read as hard facets on glossy metal under an HDRI), while skipping edges
+    whose endpoint normals already disagree by more than `crease_deg` so real
+    creases (flutes, blade edges, panel borders) stay sharp.
+
+    Controlled via env vars (read by the caller):
+        PIXAL3D_NORMAL_SMOOTH_ITERS   (int, 0 = off)
+        PIXAL3D_NORMAL_SMOOTH_CREASE  (float degrees, default 40)
+    """
+    if iters <= 0:
+        return vertex_normal
+    fi = faces.long()
+    # Undirected edge list from triangles (both directions for scatter)
+    src = torch.cat([fi[:, 0], fi[:, 1], fi[:, 2], fi[:, 1], fi[:, 2], fi[:, 0]])
+    dst = torch.cat([fi[:, 1], fi[:, 2], fi[:, 0], fi[:, 0], fi[:, 1], fi[:, 2]])
+    cos_crease = float(np.cos(np.radians(crease_deg)))
+    V = vertex_normal.shape[0]
+    for _ in range(iters):
+        n_src = vertex_normal[src]
+        n_dst = vertex_normal[dst]
+        # Only diffuse across edges that are NOT creases
+        w = (torch.sum(n_src * n_dst, dim=1, keepdim=True) > cos_crease).float()
+        acc = torch.zeros_like(vertex_normal)
+        cnt = torch.zeros((V, 1), dtype=vertex_normal.dtype, device=vertex_normal.device)
+        acc.index_add_(0, dst, n_src * w)
+        cnt.index_add_(0, dst, w)
+        neighbor_mean = acc / cnt.clamp(min=1.0)
+        vertex_normal = F.normalize(vertex_normal + neighbor_mean, dim=1)
+    return vertex_normal
+
